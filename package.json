{
  "name":
    "evm-chains-info",
  "version":
    "0.0.8",
  "description":
    "Returns information about Ethereum Virtual Machine (EVM) blockchains.",
  "funding": {
    "type":
      "patreon",
    "url":
      "https://patreon.com/tallero"
  },
  "man": [
    "./man/evm-chains-info.js.1"
  ],
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "README.md",
    "evm-chains-info",
    "evm-chains-info.js",
    "libevm-chains-info",
    "libevm-chains-info.js",
    "fs-worker.js",
    "fs-worker.webpack.config.js",
    "index.html",
    "package.json",
    "serve.json",
    "webpack.config.js"
  ],
  "keywords": [
    "ur",
    "themartiancompany",
    "dogeos",
    "ethereum"
  ],
  "homepage":
    "https://github.com/themartiancompany/evm-chains-info.js",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/evm-chains-info.js/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/evm-chains-info.js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author": {
    "name":
      "Pellegrino Prevete",
    "email":
      "pellegrinoprevete@gmail.com",
    "url":
      "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.6",
    "flatted":
      "^3.2.9",
    "eslint":
      "^10.0.3",
    "globals":
      "^17.3.0",
    "@eslint/js":
      "^10.0.1",
    "safely-serve":
      "^0.0.9",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "crash-js":
      "^0.1.96",
    "ethereum-data":
      "^0.0.3",
    "yargs":
      "18.0.0"
  },
  "type":
    "commonjs",
  "main":
    "libevm-chains-info",
  "bin":
    { "evm-chains-info.js":
        "evm-chains-info" },
  "scripts": {
    "build-fs-worker":
      "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details",
    "build-lib":
      "npx webpack --mode 'production' --config 'libevm-chains-info.webpack.config.cjs' --stats-error-details",
    "build-bin":
      "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details",
    "build":
      "npm run lint && npm run build-fs-worker && npm run build-lib && npm run build-bin",
    "lint":
      "npx eslint .",
    "publish-pnm":
      "npm run build && npm publish --access public",
    "start":
      "npx safely-serve --help # index.html --port 3000 --https --no-cache",
    "test":
      "echo \"Error: no test specified\" && exit 1"
  }
}
