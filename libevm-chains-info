}

function
  _evm_chains_info(
    _target_command,
    _input_type,
    _output_type,
    _retrieval_mode,
    _selection_method,
    _api_key,
    _networks_all,
    _target_chain,
    _db_paths) {
  if ( _target_command == "get" ) {
    _evm_chains_info_get(
      _target_chain,
      _retrieval_mode,
      _input_type,
      _selection_method,
      _db_paths);
  }
  else if ( _target_command == "set" ) {
    _evm_chains_info_set(
      _input_type);
  }
  else {
    const
      _msg =
        `Unknown command ` +
        `'${_target_command}'.`;
    _msg_error(
      _msg,
      1);
  }
}

