function
  _input_type_auto_detect() {
  if ( input_type == "" ) {
    if ( isNaN(target_chain) ) {
      input_type =
        "name";
    }
    else {
      input_type =
        "id";
    }
  }
}

function
  _db_path_auto_detect() {
  let
    _chains,
    _type_primary,
    _type_fallback,
    _msg;
  if ( user_level == "y" ) {
    _type_primary =
      "user";
    _type_fallback =
      "system";
  }
  else if ( user_level == "n" ) {
    _type_primary =
      "system";
    _type_fallback =
      "user";
  }
  const
    _db =
      _evm_chains_db_path_get(
        _type_primary,
        "",
        "unified");
  const
    _db_split =
      _evm_chains_db_path_get(
        _type_primary,
        _chain_id,
        "split");
  const
    _db_fallback =
      _db_default_path_get(
        _type_fallback,
        "",
        "unified");
  const
    _db_fallback_split =
      _db_default_path_get(
        _type_fallback,
        "split");
  if ( _file_exists(
           _db_split) ) {
    db_paths.push(
      _db_split);
  }
  else {
    _msg =
      `Default per-network database ` +
      `'${_db_split}' ` +
      `not found, trying '${_db}'.`;
    _msg_info(
      _msg);
  }
  if ( _file_exists(
         _db) ) {
    db_paths.push(
      _db);
  }
  else {
    _msg =
      `Default unified database ` +
      `'${_db_split}' ` +
      `not found, trying '${_db}'.`;
    _msg_info(
      _msg);
  }
  if ( _file_exists(
           _db_fallback_split) ) {
    db_paths.push(
      _db_fallback_split);
  }
  else {
    _msg =
      `Fallback per-network database ` +
      `'${_db_fallback_split}' ` +
      `not found, trying '${_db_fallback}'.`;
    _msg_info(
      _msg);
  }
  if ( _file_exists(
         _db_fallback) ) {
    db_paths.push(
      _db_fallback);
  }
  else {
    _msg =
      `Fallback database ` +
      `'${_db_fallback_split}' ` +
      `not found too!`;
    _msg_error(
      _msg,
      1);
  }
}

function
  _evm_chains_info_get(
    _retrieval_mode,
    _input_type,
    _selection_method,
    _db_paths) {
  let
    _db,
    _db_path,
    _msg,
    _networks_total,
    _results;
  _networks_total =
    0;
  if ( _retrieval_mode == "offline" ) {
    for ( _db_path of _db_paths ) {
      _msg =
        `Looking in '${_db_path}'.`;
      _msg_info(
        _msg);
      _db_path_check(
        _db_path);
      if ( _input_type != "amount" ) {
        _db_get(
	  _db_path,
          _input_type,
          _output_type,
          _selection_method,
          _api_key,
          _target_chain);
      }
      else if ( _input_type == "amount" ) {
        _db =
          _json_read(
            _db_path);
	_networks_total =
          _db.length;
      }
    }
    if ( _input_type != "amount" ) {
      if ( _results.length == 0 ) {
        _msg =
          `No results found for network ` +
          `'${_target_chain}'.`;
        _msg_error(
          _msg,
          0);
      }
      for ( _result of _results ) {
        console.log(
          _result);
        if ( _selection_method != "all" ) {
          break;
        }
      }
    }
    else if ( _input_type == "amount" ) {
      console.log(
        _networks_total);
    }
  }
  else if ( _retrieval_mode == "online" ) {
    _msg =
      `About to implement it probably.`;
    _msg_error(
      _msg,
      1);
  }
}

function
  _evm_chains_info_set(
