function
  _evm_chains_db_path_get(
    _user,
    _chain_id,
    _format) {
  let
    _db_exists,
    _db_name,
    _path;
  if ( typeof(
         _user) == "undefined" ) {
    _user =
      false;
  }
  if ( typeof(
         _chain_id) == "undefined" ) {
    _chain_id =
      "";
  }
  if ( typeof(
         _format) == "undefined" ) {
    if ( _chain_id != "" ) {
      _format =
        "split";
    }
    else if ( _chain_id == "" ) {
    _format =
      "unified";
    }
  }
  if ( _format == "unified" ) {
    _db_name =
      "chains.json";
  }
  else if ( _format == "split" ) {
    _db_name =
      `${_chain_id}.json`;
  }
  if ( _user == true ) {
    _path =
      _path_join(
        [_homedir_get(),
         ".config",
         "evm-chains",
         _db_name]);
    const
      _db_exists =
        _file_exists(
          _db_path);
    if ( _db_exists == false ) {
      _user =
        false;
    }
  }
  if ( _user == false ) {
    _path =
      _path_join(
        [process.env.NODE_PATH,
         "..",
         "evm-chains",
         "chains.json"]);
  }
  else {
    _msg_error(
      "Input variable '_user' must be a boolean",
      0);
  }
  return _path;
}

function
  _evm_chain_info_get(
    _chain_id,
    _chain_info,
    _db_path) {
  let
    _data,
    _db;
  if ( typeof(
         _db_path) == "undefined" ) {
    _db_path =
      _evm_chains_db_path_get(
        false);
  }
  const
    _db_exists =
      _file_exists(
        _db_path);
  if ( _db_exists == false ) {
    if ( typeof window === 'undefined' &&
         ( typeof global !== 'undefined' && global.global === global ) &&
         typeof __webpack_require__ !== 'function' ) {
      _data =
        _data_get(
          _chain_id);
      _msg =
        `Displaying data for ` +
        `chain '${_chain_id}'.`;
      _msg_info(
        _msg);
      console.log(
        _data);
    }
    // _msg_error(
    //   "Database file does not exists.",
    //   1);
  }
  _db =
    _json_read(
      _db_path);
  for ( _chain_info of _db) {
    if ( _chain_info["chainId"] == _chain_id ) {
      return _chain_info;
    }
  }
  _msg_error(
    `Network '${_chain_id}' not found.`,
    1);
}

function
  _rpc_backend_get(
    _network_chain_id,
    _selection_method,
    _db_path) {
  let
    _chain_id,
    _chain_info;
  if ( _network_chain_id == undefined ) {
    _msg_error(
      "Network's ChainID not specified.",
      1);
  }
  if ( _selection_method == undefined ) {
    _selection_method =
      "kirsh";
  }
  if ( _db_path == undefined ) {
    _db_path =
      _evm_chains_db_path_get(
        false);
  }
  _chain_id =
    Number(
      _network_chain_id);
  _chain_info =
    _evm_chain_info_get(
      _chain_id,
      _db_path);
  if ( _selection_method == "kirsh" ) {
    return _chain_info["rpc"][0];
  }
  else {
    _msg_error(
      "Unknown selection method.",
      1);
  }
}

function _rpc_backends_get(
    _networks_chain_ids,
    _selection_method,
    _db_path) {
    let
      _chain_id,
      _rpc_backend_get_opts,
      _rpcs;
  if ( _selection_method == undefined ) {
    _selection_method =
      "kirsh";
  }
  if ( _db_path == undefined ) {
    _db_path =
      _evm_chains_db_path_get(
        false);
  }
  _rpcs =
    [];
  for ( _chain_id of _networks_chain_ids ) {
    _rpc_backend_get_opts = [
      _chain_id,
      _selection_method,
      _db_path
    ];
    _rpc_backend =
      _rpc_backend_get.apply(
        null,
        _rpc_backend_get_opts);
    _rpcs.append(
      _rpc_backend);
  }
  return _rpcs;
}

function
  _db_path_check(
    _db_path) {
  if ( ! _file_exists(
       _db_path) ) {
    const
      _msg =
        `Database at ` +
        `'${_db_path}' does not exist.`;
    _msg_error(
      _msg,
      1);
  }
}

